---
import "../styles/app.css";
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#1a0a2e" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="My Jobs" />
    <meta name="description" content="Safe, checked entry-level jobs near Grimes & Des Moines — scam-screened, no degree needed." />
    <link rel="manifest" href={`${base}manifest.webmanifest`} />
    <link rel="apple-touch-icon" href={`${base}apple-touch-icon.png`} />
    <link rel="icon" href={`${base}icon-192.png`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:ital,wght@0,400;0,700;1,400&family=Cinzel:wght@500;600;700&display=swap" rel="stylesheet" />
    <title>Jobs for you — Grimes & Des Moines</title>
  </head>
  <body>
    <div class="app">
      <header class="topbar">
        <div class="brand">
          <h1>Jobs for you</h1>
          <p id="meta-generated">Loading safe jobs…</p>
        </div>
        <span class="badge-safe" aria-label="Scam shield active">🛡 Scam-checked</span>
        <div class="acct">
          <button type="button" class="acct-btn" id="acct-btn" aria-label="Account">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="12" cy="8" r="4" /><path d="M4 20c0-4 4-6 8-6s8 2 8 6" />
            </svg>
          </button>
        </div>
      </header>

      <nav class="nav-side" aria-label="Main">
        <button type="button" class="tab" data-view="jobs" aria-current="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
          Jobs
        </button>
        <button type="button" class="tab" data-view="today">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>
          Today
        </button>
        <button type="button" class="tab" data-view="apps">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
          My apps
        </button>
        <button type="button" class="tab" data-view="corner">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          My corner
        </button>
        <button type="button" class="tab" data-view="help">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          Help
        </button>
      </nav>

      <div class="main-col">
        <main id="view-host" aria-live="polite"></main>
      </div>
    </div>

    <nav class="nav-bottom" aria-label="Main">
      <button type="button" class="tab" data-view="jobs" aria-current="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
        Jobs
      </button>
      <button type="button" class="tab" data-view="today">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>
        Today
      </button>
      <button type="button" class="tab" data-view="apps">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
        Apps
      </button>
      <button type="button" class="tab" data-view="corner">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        Corner
      </button>
      <button type="button" class="tab" data-view="help">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        Help
      </button>
    </nav>

    <div class="modal-back" id="auth-modal" hidden>
      <div class="modal" role="dialog" aria-labelledby="auth-title">
        <button type="button" class="modal-x" id="auth-close" aria-label="Close">&times;</button>
        <h2 id="auth-title">Free account</h2>
        <p class="job-meta">Today, her applications, Rudy, and résumé tailoring — saved instantly across devices.</p>
        <input class="field" id="auth-email" type="email" autocomplete="email" placeholder="Email" />
        <input class="field" id="auth-pass" type="password" autocomplete="current-password" placeholder="Password" />
        <button type="button" class="btn btn-primary" id="auth-signin" style="width:100%;margin-top:12px">Sign in</button>
        <button type="button" class="btn btn-ghost" id="auth-signup" style="width:100%;margin-top:8px">Create account</button>
      </div>
    </div>

    <div class="modal-back" id="tailor-modal" hidden>
      <div class="modal modal-wide" role="dialog" aria-labelledby="tailor-title">
        <button type="button" class="modal-x" id="tailor-close" aria-label="Close">&times;</button>
        <h2 id="tailor-title">✦ Résumé tailor</h2>
        <div id="tailor-body"></div>
      </div>
    </div>

    <div class="rudy-overlay" id="rudy-overlay" hidden>
      <div class="rudy-bar">
        <img class="rudy-avatar rudy-avatar--lg" src={`${base}rudy.jpg`} alt="" width="44" height="44" />
        <div style="flex:1">
          <strong style="font-family:var(--font-display)">Rudy</strong>
          <div class="job-meta" style="font-size:var(--text-xs)">Emotional support cow</div>
        </div>
        <button type="button" class="btn btn-ghost" id="rudy-close">Close</button>
      </div>
      <div class="rudy-log" id="rudy-log"></div>
      <div class="rudy-dock">
        <input class="rudy-input" id="rudy-input" type="text" placeholder="How is she doing today?" autocomplete="off" />
        <button type="button" class="btn btn-primary" id="rudy-send">Send</button>
      </div>
    </div>

    <div class="toast" id="toast" role="status" aria-live="polite"></div>

    <script type="module" src="../scripts/app.ts"></script>
  </body>
</html>
