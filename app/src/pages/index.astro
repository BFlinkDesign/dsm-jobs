---
import "../styles/app.css";
const base = import.meta.env.BASE_URL;
const sentryDsn = import.meta.env.SENTRY_DSN ?? "";
const sentryDsnJson = JSON.stringify(sentryDsn);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#1a0a2e" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="My Jobs" />
    <meta name="description" content="Safe, checked entry-level jobs near Grimes & Des Moines — scam-screened, no degree needed." />
    <link rel="manifest" href={`${base}manifest.webmanifest`} />
    <link rel="apple-touch-icon" href={`${base}apple-touch-icon.png`} />
    <link rel="icon" href={`${base}icon-192.png`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:ital,wght@0,400;0,700;1,400&family=IBM+Plex+Sans+Condensed:wght@600;700&display=swap" rel="stylesheet" />
    <title>Jobs for you — Grimes & Des Moines</title>
    {sentryDsn ? (
      <>
        <script
          is:inline
          src="https://browser.sentry-cdn.com/10.57.0/bundle.tracing.min.js"
          integrity="sha384-fm7orKrUHTJhAKcdqNq6Kb/0qIpMNYz3TbwoEoiA3hdbnHqSBhIqMAZ4XS09pCU5"
          crossorigin="anonymous"
        />
        <script is:inline define:vars={{ sentryDsnJson }}>
          (function () {
            if (!window.Sentry) return;
            try {
              var dsn = JSON.parse(sentryDsnJson);
              if (!dsn) return;
              Sentry.init({
                dsn: dsn,
                sendDefaultPii: false,
                tracesSampleRate: 0.1,
                beforeBreadcrumb: function (crumb) {
                  if (crumb && crumb.category === "ui.input") return null;
                  if (crumb && crumb.data) {
                    delete crumb.data.from;
                    delete crumb.data.to;
                  }
                  return crumb;
                },
                beforeSend: function (event) {
                  delete event.user;
                  delete event.request;
                  delete event.contexts;
                  delete event.server_name;
                  return event;
                },
              });
            } catch (e) {
              /* monitoring must never break the app */
            }
          })();
        </script>
      </>
    ) : null}
  </head>
  <body>
    <div class="app">
      <header class="topbar">
        <div class="brand">
          <h1>Jobs for you</h1>
          <p id="meta-generated">Researching safe jobs near Des Moines…</p>
        </div>
        <span class="badge-safe" aria-label="Scam shield active">🛡 Scam-checked</span>
        <div class="acct">
          <button type="button" class="acct-btn" id="acct-btn" aria-label="Account">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="12" cy="8" r="4" /><path d="M4 20c0-4 4-6 8-6s8 2 8 6" />
            </svg>
          </button>
        </div>
      </header>

      <nav class="nav-side" aria-label="Main">
        <button type="button" class="tab" data-view="jobs" aria-current="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
          Jobs
        </button>
        <button type="button" class="tab" data-view="today">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>
          Today
        </button>
        <button type="button" class="tab" data-view="apps">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
          My apps
        </button>
        <button type="button" class="tab" data-view="corner">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          My corner
        </button>
        <button type="button" class="tab" data-view="help">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          Help
        </button>
        <button type="button" class="tab" data-view="money">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.8 5.6a5.5 5.5 0 00-7.8 0L12 6.6l-1-1a5.5 5.5 0 00-7.8 7.8l1 1L12 22l7.8-7.6 1-1a5.5 5.5 0 000-7.8z"/></svg>
          Money
        </button>
      </nav>

      <div class="main-col">
        <div class="banner banner-offline" id="offline-banner" hidden>No internet — showing what we saved on this phone.</div>
        <div class="banner banner-sync" id="sync-banner" role="status" aria-live="polite" hidden></div>
        <div class="banner banner-stale" id="stale-banner" hidden></div>
        <main id="view-host" aria-live="polite"></main>
      </div>
    </div>

    <nav class="nav-bottom" aria-label="Main">
      <button type="button" class="tab" data-view="jobs" aria-current="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
        Jobs
      </button>
      <button type="button" class="tab" data-view="today">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>
        Today
      </button>
      <button type="button" class="tab" data-view="apps">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
        Apps
      </button>
      <button type="button" class="tab" data-view="corner">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        Corner
      </button>
      <button type="button" class="tab" data-view="help">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        Help
      </button>
      <button type="button" class="tab" data-view="money">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.8 5.6a5.5 5.5 0 00-7.8 0L12 6.6l-1-1a5.5 5.5 0 00-7.8 7.8l1 1L12 22l7.8-7.6 1-1a5.5 5.5 0 000-7.8z"/></svg>
        Money
      </button>
    </nav>

    <div class="modal-back" id="auth-modal" hidden>
      <div class="modal" role="dialog" aria-modal="true" aria-labelledby="auth-title">
        <button type="button" class="modal-x" id="auth-close" aria-label="Close">&times;</button>
        <div id="auth-main">
          <h2 id="auth-title">Welcome back ✦</h2>
          <p class="job-meta" id="auth-sub">Sign in so your jobs, notes and chats follow you to any device.</p>
          <input class="field" id="auth-email" type="email" autocomplete="username" placeholder="Email" />
          <div class="field-password">
            <input class="field" id="auth-pass" type="password" autocomplete="current-password" placeholder="Password" />
            <button type="button" class="field-password-toggle" aria-label="Show password" aria-pressed="false">
              <svg class="field-password-icon field-password-icon--show" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              <svg class="field-password-icon field-password-icon--hide is-hidden" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
            </button>
          </div>
          <button type="button" class="btn btn-primary" id="auth-signin" style="width:100%;margin-top:12px">Sign in</button>
          <button type="button" class="btn btn-ghost" id="auth-signup" style="width:100%;margin-top:8px">Create account</button>
          <button type="button" class="btn btn-ghost" id="auth-magic" style="width:100%;margin-top:8px">Email me a sign-in link</button>
          <button type="button" class="btn btn-ghost" id="auth-google" hidden style="width:100%;margin-top:8px">Continue with Google</button>
          <div class="auth-links">
            <button type="button" class="auth-link" id="auth-toggle">New here? Create an account</button>
            <button type="button" class="auth-link" id="auth-forgot">Forgot password?</button>
          </div>
          <p class="auth-divider" id="auth-pk-div">or, if you like</p>
          <button type="button" class="btn btn-ghost" id="auth-passkey" style="width:100%">Use Face ID / fingerprint</button>
          <p class="field-hint" id="auth-msg" role="status"></p>
        </div>
        <div id="auth-forgot-panel" hidden>
          <h2 id="auth-forgot-title">Reset your password ✦</h2>
          <p class="job-meta" id="auth-forgot-sub">Enter your email and we'll send a link to set a new password.</p>
          <input class="field" id="auth-forgot-email" type="email" autocomplete="username" placeholder="Email" />
          <button type="button" class="btn btn-primary" id="auth-send-reset" style="width:100%;margin-top:12px">Send reset link</button>
          <button type="button" class="auth-link auth-link--block" id="auth-forgot-back">Back to sign in</button>
          <p class="field-hint" id="auth-forgot-msg" role="status"></p>
        </div>
        <div id="auth-recover" hidden>
          <h2>Set a new password ✦</h2>
          <p class="job-meta">Pick a new password for your account.</p>
          <div class="field-password">
            <input class="field" id="auth-newpass" type="password" autocomplete="new-password" placeholder="New password (8+ characters)" />
            <button type="button" class="field-password-toggle" aria-label="Show password" aria-pressed="false">
              <svg class="field-password-icon field-password-icon--show" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              <svg class="field-password-icon field-password-icon--hide is-hidden" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
            </button>
          </div>
          <div class="field-password">
            <input class="field" id="auth-newpass-confirm" type="password" autocomplete="new-password" placeholder="Confirm new password" />
            <button type="button" class="field-password-toggle" aria-label="Show password" aria-pressed="false">
              <svg class="field-password-icon field-password-icon--show" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              <svg class="field-password-icon field-password-icon--hide is-hidden" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
            </button>
          </div>
          <button type="button" class="btn btn-primary" id="auth-setpass" style="width:100%;margin-top:12px">Save new password</button>
          <p class="field-hint" id="auth-recmsg" role="status"></p>
        </div>
      </div>
    </div>

    <div class="modal-back" id="ios-install-modal" hidden>
      <div class="modal update-modal card-glitter" role="dialog" aria-modal="true" aria-labelledby="ios-install-title">
        <button type="button" class="modal-x" id="ios-install-close" aria-label="Close">&times;</button>
        <div class="update-spark" aria-hidden="true">✦</div>
        <h2 id="ios-install-title" class="update-title">Keep this on your phone</h2>
        <p class="update-sub">Two taps and jobs live right on your home screen — just like a real app.</p>
        <ol class="coach-steps">
          <li>Tap the <b>Share</b> button at the bottom of Safari <span aria-hidden="true">⬆️</span></li>
          <li>Scroll and tap <b>Add to Home Screen</b></li>
          <li>Tap <b>Add</b> — done! ✦</li>
        </ol>
        <button type="button" class="btn update-go" id="ios-install-ok">Got it!</button>
      </div>
    </div>

    <!-- Guided "Show me around" walkthrough — interactive, driven by renderTour() -->
    <div class="tour-root" id="tour-root" hidden>
      <div class="tour-dim" id="tour-dim"></div>
      <div class="tour-ring" id="tour-ring" hidden></div>
      <div class="tour-progress"><span class="tour-progress-bar" id="tour-progress-bar"></span></div>
      <button type="button" class="tour-skip" id="tour-skip">Skip</button>
      <div class="tour-pop pop-in" id="tour-pop" role="dialog" aria-modal="true" aria-labelledby="tour-h">
        <div class="tour-emoji" id="tour-emoji" aria-hidden="true">✦</div>
        <h2 id="tour-h" class="tour-h"></h2>
        <p id="tour-p" class="tour-p"></p>
        <div class="tour-chips" id="tour-chips" hidden></div>
        <div class="tour-foot">
          <button type="button" class="tour-back" id="tour-back" hidden>‹ Back</button>
          <button type="button" class="btn update-go tour-next" id="tour-next">Next</button>
        </div>
      </div>
    </div>

    <input type="file" id="resume-file" accept=".docx,.pdf,.txt,.md,.markdown" hidden />

    <footer class="app-foot" id="app-foot">
      <p class="field-hint">Tip: tap Share on a job, then <b>Add to Home Screen</b> to keep this on your phone.</p>
      <button type="button" class="btn btn-ghost install-btn" id="install-btn" hidden>Add this app to your phone</button>
    </footer>

    <div class="modal-back" id="tailor-modal" hidden>
      <div class="modal modal-wide" role="dialog" aria-labelledby="tailor-title">
        <button type="button" class="modal-x" id="tailor-close" aria-label="Close">&times;</button>
        <h2 id="tailor-title">✦ Résumé tailor</h2>
        <div id="tailor-body"></div>
      </div>
    </div>

    <div class="rudy-overlay" id="rudy-overlay" hidden>
      <div class="rudy-bar">
        <img class="rudy-avatar rudy-avatar--lg" src={`${base}rudy.jpg`} alt="" width="44" height="44" />
        <div style="flex:1">
          <strong style="font-family:var(--font-display)">Rudy</strong>
          <div class="job-meta" style="font-size:var(--text-xs)">Emotional support cow for jobs, nerves, and real life</div>
        </div>
        <button type="button" class="btn btn-ghost rudy-tone-btn" id="rudy-memory-open" aria-pressed="false" title="See and clear what Rudy remembers">
          Memory
        </button>
        <button type="button" class="btn btn-ghost rudy-tone-btn" id="rudy-spicy" aria-pressed="false" title="Spicy mode is off">
          Spicy
        </button>
        <button type="button" class="btn btn-ghost" id="rudy-close">Close</button>
      </div>
      <div class="rudy-log" id="rudy-log"></div>
      <div class="rudy-memory" id="rudy-memory" hidden>
        <div class="rudy-memory-head">
          <h3 class="section-title">What Rudy remembers</h3>
          <button type="button" class="btn btn-ghost btn-sm" id="rudy-memory-close">Back to chat</button>
        </div>
        <p class="job-meta">This is everything Rudy actually knows about you — nothing more. Delete anything you want forgotten.</p>
        <div id="rudy-memory-body"></div>
      </div>
      <div class="rudy-prompts" aria-label="Quick Rudy prompts">
        <button type="button" class="btn btn-ghost btn-sm" data-rudy-prompt="I'm overwhelmed. Help me pick one tiny next step.">Overwhelmed</button>
        <button type="button" class="btn btn-ghost btn-sm" data-rudy-prompt="Give me a spicy pep talk, but keep it useful.">Pep talk</button>
        <button type="button" class="btn btn-ghost btn-sm" data-rudy-prompt="What do you actually remember about me?">Memory check</button>
      </div>
      <div class="rudy-dock">
        <!-- Tap to talk to Rudy (MediaRecorder -> voice Edge Function; wired in app.ts, hidden if mic unavailable) -->
        <button type="button" class="rudy-mic" id="rudy-mic" aria-label="Tap to talk to Rudy" aria-pressed="false" title="Tap to talk" hidden>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="9" y="2" width="6" height="12" rx="3"/><path d="M5 10a7 7 0 0014 0M12 19v3M9 22h6"/></svg>
        </button>
        <input class="rudy-input" id="rudy-input" type="text" placeholder="Ask Rudy — or tap the mic to talk" autocomplete="off" />
        <button type="button" class="btn btn-primary" id="rudy-send">Send</button>
      </div>
      <div class="rudy-voicebar">
        <!-- One clear control: should Rudy speak her replies out loud? (server voice with browser fallback; wired in app.ts) -->
        <button type="button" class="rudy-readaloud" id="rudy-spk" aria-pressed="false">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M11 5L6 9H2v6h4l5 4V5z"/><path d="M19.07 4.93a10 10 0 010 14.14M15.54 8.46a5 5 0 010 7.07"/></svg>
          <span>Rudy reads replies aloud</span>
          <span class="rudy-readaloud-state" id="rudy-spk-state">Off</span>
        </button>
        <span class="rudy-listen" id="rudy-listen" hidden>● Listening…</span>
      </div>
      <!-- Voice picker: only meaningful once read-aloud is on (JS shows/hides
           via [hidden]; wired in app.ts). Tapping an option both selects it
           and plays a short preview line, throttled to one in flight. -->
      <div class="rudy-voice-picker" id="rudy-voice-picker" role="group" aria-label="Rudy's voice" hidden>
        <button type="button" class="rudy-voice-opt" data-voice="warm" aria-pressed="true">Warm</button>
        <button type="button" class="rudy-voice-opt" data-voice="bright" aria-pressed="false">Bright</button>
        <button type="button" class="rudy-voice-opt" data-voice="calm" aria-pressed="false">Calm</button>
        <button type="button" class="rudy-voice-opt" data-voice="spark" aria-pressed="false">Spark</button>
      </div>
      <p class="rudy-voice-status" id="rudy-voice-status" role="status" aria-live="polite">Voice is off.</p>
      <p class="rudy-crisis">Need help now? <a href="tel:988"><b>988</b></a> (call/text, 24/7) · Your Life Iowa <a href="tel:8555818111">855-581-8111</a> · Iowa Warm Line <a href="tel:8447759276">844-775-9276</a>. Always free.</p>
    </div>

    <!-- Iowa printable work-search log — populated by printWorkLog(), shown only during window.print() -->
    <div id="print-worklog" hidden></div>

    <div class="modal-back update-back" id="update-modal" hidden>
      <div class="modal update-modal card-glitter" role="dialog" aria-modal="true" aria-labelledby="update-title">
        <div class="update-spark" aria-hidden="true">✦</div>
        <h2 id="update-title" class="update-title">Fresh update is here!</h2>
        <p class="update-sub">New jobs and improvements just landed for you.</p>
        <button type="button" class="btn update-go" id="update-go">LETTSSSS GOO!</button>
      </div>
    </div>

    <div class="toast" id="toast" role="status" aria-live="polite"></div>

    <script>
      import "../scripts/app.ts";
    </script>
  </body>
</html>
